  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment", "string.quoted.docstring.multi"],
      "settings": { "foreground": "#9e9484", "fontStyle": "italic" }
    },
    {
      "name": "Keywords — hibiscus",
      "scope": [
        "keyword", "keyword.control", "keyword.operator.logical",
        "keyword.other", "storage", "storage.type", "storage.modifier",
        "constant.language", "variable.language.this", "variable.language.self",
        "keyword.operator.new", "keyword.operator.delete",
        "support.type.primitive"
      ],
      "settings": { "foreground": "#d04550" }
    },
    {
      "name": "Functions — sage",
      "scope": [
        "entity.name.function", "entity.name.method",
        "support.function", "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": { "foreground": "#6aaa44" }
    },
    {
      "name": "Types & Classes — river moss",
      "scope": [
        "entity.name.type", "entity.name.class", "entity.name.namespace",
        "support.class", "support.type", "entity.other.inherited-class",
        "meta.return-type", "entity.name.exception", "entity.name.interface",
        "entity.name.trait", "entity.name.enum"
      ],
      "settings": { "foreground": "#2ea882" }
    },
    {
      "name": "Strings — ochre",
      "scope": [
        "string", "string.quoted", "string.interpolated",
        "constant.character", "string.template", "string.regexp"
      ],
      "settings": { "foreground": "#c87838" }
    },
    {
      "name": "Numbers — slate sky",
      "scope": ["constant.numeric", "constant.other.color", "constant.other.unit"],
      "settings": { "foreground": "#4878ba" }
    },
    {
      "name": "Operators & Decorators — thistle",
      "scope": [
        "keyword.operator", "keyword.operator.assignment",
        "keyword.operator.comparison", "keyword.operator.arithmetic",
        "keyword.operator.bitwise", "keyword.operator.type",
        "punctuation.definition.decorator", "entity.name.function.decorator",
        "meta.decorator", "storage.type.annotation"
      ],
      "settings": { "foreground": "#b070d0" }
    },
    {
      "name": "Variables & Identifiers — fg0",
      "scope": ["variable", "variable.other", "variable.other.readwrite", "meta.definition.variable"],
      "settings": { "foreground": "#ead6b4" }
    },
    {
      "name": "Parameters — fg0 italic",
      "scope": ["variable.parameter", "meta.function.parameter variable"],
      "settings": { "foreground": "#ead6b4", "fontStyle": "italic" }
    },
    {
      "name": "Punctuation — fg1",
      "scope": [
        "punctuation", "meta.brace", "meta.bracket",
        "punctuation.accessor", "punctuation.separator",
        "punctuation.terminator", "punctuation.definition.block",
        "punctuation.definition.binding-pattern"
      ],
      "settings": { "foreground": "#d2be9e" }
    },
    {
      "name": "HTML/JSX Tags — hibiscus",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": { "foreground": "#d04550" }
    },
    {
      "name": "HTML Attributes — sage",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#6aaa44" }
    },
    {
      "name": "CSS Properties — sage",
      "scope": ["support.type.property-name.css", "meta.property-name"],
      "settings": { "foreground": "#6aaa44" }
    },
    {
      "name": "CSS Values — ochre",
      "scope": ["support.constant.property-value", "meta.property-value support.constant"],
      "settings": { "foreground": "#c87838" }
    },
    {
      "name": "CSS Selectors — moss",
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#2ea882" }
    },
    {
      "name": "Markdown Headings — hibiscus bold",
      "scope": ["markup.heading", "entity.name.section.markdown", "punctuation.definition.heading.markdown"],
      "settings": { "foreground": "#d04550", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#ead6b4", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#ead6b4", "fontStyle": "italic" }
    },
    {
      "name": "Markdown Inline Code — moss",
      "scope": ["markup.inline.raw", "markup.raw.block", "fenced_code.block.language"],
      "settings": { "foreground": "#2ea882" }
    },
    {
      "name": "Markdown Links — slate",
      "scope": ["markup.underline.link", "string.other.link.title.markdown"],
      "settings": { "foreground": "#4878ba" }
    },
    {
      "name": "Markdown Blockquote — ochre",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#c87838", "fontStyle": "italic" }
    },
    {
      "name": "JSON Keys — sage",
      "scope": ["support.type.property-name.json", "meta.object-literal.key"],
      "settings": { "foreground": "#6aaa44" }
    },
    {
      "name": "Import modules — moss",
      "scope": ["entity.name.module", "keyword.control.import.from"],
      "settings": { "foreground": "#2ea882" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#d04550", "fontStyle": "underline" }
    }
  ],

  "semanticTokenColors": {
    "function": "#6aaa44",
    "method": "#6aaa44",
    "class": "#2ea882",
    "type": "#2ea882",
    "interface": "#2ea882",
    "enum": "#2ea882",
    "enumMember": "#4878ba",
    "parameter": { "foreground": "#ead6b4", "italic": true },
    "variable.readonly": "#4878ba",
    "keyword": "#d04550",
    "string": "#c87838",
    "number": "#4878ba",
    "operator": "#b070d0",
    "decorator": "#b070d0",
    "comment": { "foreground": "#9e9484", "italic": true },
    "macro": "#d04550",
    "namespace": "#2ea882",
    "property": "#ead6b4"
  }
}
